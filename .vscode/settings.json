{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "files.associations": {
    "renovate.json": "jsonc",
    ".envrc.project": "dotenv",
    ".envrc": "dotenv",
    ".sqlfluff": "toml",
    "*.css": "tailwindcss"
  },

  "explorer.fileNesting.patterns": {
    ".envrc.project": ".envrc",
    "buf.yaml": "buf.gen.yaml,buf.lock",
    "flake.nix": "flake.lock,treefmt.toml",
    "README.md": "*.md,LICENSE",
    "package.json": "package-lock.json,.npmrc"
  },

  "json.schemaDownload.trustedDomains": {
    "https://docs.renovatebot.com/": true
  },

  "chat.tools.terminal.autoApprove": {
    "treefmt": true,

    // nix
    "nix build": true,
    "nix flake check": true,

    // npm
    "npm run dev": true,
    "npm install": true,
    "npm update": true,
    "npm audit fix": true,

    // go
    "go run": true,
    "go mod tidy": true,
    "go mod vendor": true
  },

  // nix
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "(builtins.getFlake (builtins.toString ./.)).outputs.nixpkgs.${builtins.currentSystem}"
      }
    }
  },
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },

  // go
  "go.buildTags": "dev",
  "gopls": { "ui.semanticTokens": true },
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },

  // biome
  "biome.enabled": true,
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[html]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[tailwindcss]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },

  // proto
  "[proto]": {
    "editor.defaultFormatter": "bufbuild.vscode-buf"
  },

  // sql
  "[sql]": {
    "editor.defaultFormatter": "sqlfluff.vscode-sqlfluff"
  },

  // toml
  "[toml]": {
    "editor.defaultFormatter": "tombi-toml.tombi"
  }
}
