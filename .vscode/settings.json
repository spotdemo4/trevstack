{
  "files.associations": {
    "renovate.json": "jsonc",
    ".envrc.project": "dotenv",
    ".envrc": "dotenv",
    ".sqlfluff": "toml",
    "*.css": "tailwindcss"
  },

  "explorer.fileNesting.patterns": {
    ".envrc.project": ".envrc",
    "buf.yaml": "buf.gen.yaml,buf.lock",
    "flake.nix": "flake.lock,treefmt.toml",
    "README.md": "*.md,LICENSE",
    "package.json": "package-lock.json,.npmrc"
  },

  "json.schemaDownload.trustedDomains": {
    "https://docs.renovatebot.com/": true
  },

  "chat.tools.terminal.autoApprove": {
    "treefmt": true,

    // go
    "go run": true,
    "go mod tidy": true,
    "go mod vendor": true,

    // npm
    "npm run dev": true,
    "npm install": true,
    "npm update": true,
    "npm audit fix": true,

    // nix
    "nix build": true,
    "nix flake check": true
  },

  // oxc.oxc-vscode
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always" // oxlint
  },

  // golang.go
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "go.buildTags": "dev",
  "gopls": { "ui.semanticTokens": true },

  // jnoortheen.nix-ide
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "(builtins.getFlake (builtins.toString ./.)).outputs.nixpkgs.${builtins.currentSystem}"
      }
    }
  },

  // bufbuild.vscode-buf
  "[proto]": {
    "editor.defaultFormatter": "bufbuild.vscode-buf"
  },

  // sqlfluff.vscode-sqlfluff
  "[sql]": {
    "editor.defaultFormatter": "sqlfluff.vscode-sqlfluff"
  }
}
