{
  "$schema": "https://docs.renovatebot.com/renovate-global-schema.json",

  // self-hosted
  "onboarding": false,
  "requireConfig": "ignored",
  "platform": "forgejo",
  "endpoint": "https://trev.zip/api/v1",
  "repositories": ["trev/stack"],
  "allowedCommands": [
    "buf dep update",
    "npm audit fix --prefix web",
    "fix-hash .#checks.x86_64-linux.protobuf",
    "fix-hash .#packages.x86_64-linux.server"
  ],

  // repository
  "extends": ["config:recommended"],
  "addLabels": ["dependency"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* * * * 0"], // sunday
    "skipInstalls": false,
    "postUpgradeTasks": {
      "commands": [
        "buf dep update",
        "npm audit fix --prefix web",
        "fix-hash .#checks.x86_64-linux.protobuf",
        "fix-hash .#packages.x86_64-linux.server"
      ]
    }
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchManagers": ["nix"],
      "addLabels": ["nix"]
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["actions"]
    },
    {
      "matchManagers": ["gomod"],
      "addLabels": ["go"],
      "postUpgradeTasks": {
        "commands": ["fix-hash .#packages.x86_64-linux.server"]
      }
    },
    {
      "matchManagers": ["npm"],
      "addLabels": ["node"],
      "rangeStrategy": "bump",
      "postUpdateOptions": ["npmInstallTwice"]
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "enabled": false
    }
  ]
}
