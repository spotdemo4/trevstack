{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",

  "formatter": {
    "enabled": true
  },

  "linter": {
    "enabled": true,
    "rules": {
      "nursery": {
        "useSortedClasses": "error"
      }
    }
  },

  "assist": {
    "enabled": true
  },

  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },

  "json": {
    "formatter": {
      "enabled": false
    },
    "parser": {
      "allowComments": true
    }
  },

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
