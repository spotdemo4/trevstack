{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",

  "files": {
    "includes": ["**", "!!**/connect", "!!**/vendor"]
  },

  "formatter": {
    "enabled": true
  },

  "linter": {
    "enabled": true
  },

  "assist": {
    "enabled": true
  },

  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },

  "json": {
    "formatter": {
      "enabled": false
    },
    "parser": {
      "allowComments": true
    }
  },

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
